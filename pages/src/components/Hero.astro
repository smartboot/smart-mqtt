---
---

<section class="hero-section" id="hero">
  <!-- 渐变球背景效果 -->
  <div class="hero-bg">
    <div class="gradient-ball ball-purple"></div>
    <div class="gradient-ball ball-cyan"></div>
    <div class="gradient-ball ball-pink"></div>
    <div class="grid-bg"></div>
  </div>
  
  <div class="hero-main">
    <div class="content-col">
      <div class="badge-row">
        <div class="badge">
          <span class="badge-dot"></span>
          <span data-i18n="hero.badge">开源 MQTT Broker</span>
        </div>
        <a href="https://hub.docker.com/r/smartboot/smart-mqtt" target="_blank" rel="noopener" class="docker-badge">
          <img src="https://img.shields.io/docker/pulls/smartboot/smart-mqtt" alt="Docker Pulls">
        </a>
      </div>
      
      <h1 class="title">
        <span class="title-line highlight" data-i18n="hero.title1">用 Java 写的 MQTT Broker</span>
        <span class="title-line">
          成本降至 <span class="cost-10">1/10</span>，出了问题
          <span class="author-highlight">找得到人</span>
        </span>
      </h1>
      
      <p class="desc" data-i18n="hero.desc">
        <span class="pain-point">✅ 99% 的企业后端是 Java，为什么你的 MQTT 要用 Erlang？</span>
        <br>
        <span class="pain-point">✅ 10万设备，某云Saas成本每年数十万，我们一台服务器搞定</span>
      </p>
      
      <div class="btn-group">
        <a href="https://gitee.com/smartboot/smart-mqtt/releases/download/v1.5.5/smart-mqtt-full-v1.5.5.zip" class="btn-primary" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span data-i18n="hero.download">下载发行包</span>
        </a>
        <a href="./product/introduction/" class="btn-secondary">
          <span data-i18n="hero.getStarted">立即开始</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
      
      <div class="requirements-bar">
        <div class="requirements-label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <span data-i18n="hero.requirements">环境要求</span>
        </div>
        <div class="requirements-items">
          <div class="req-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span>JDK 8+</span>
          </div>
          <div class="req-item os-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="os-badges">
              <span class="os-badge">Linux</span>
              <span class="os-badge">macOS</span>
              <span class="os-badge">Windows</span>
            </span>
          </div>
          <div class="req-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
              <rect x="4" y="4" width="16" height="16" rx="2" ry="2"/>
              <rect x="9" y="9" width="6" height="6"/>
              <line x1="9" y1="1" x2="9" y2="4"/>
              <line x1="15" y1="1" x2="15" y2="4"/>
              <line x1="9" y1="20" x2="9" y2="23"/>
              <line x1="15" y1="20" x2="15" y2="23"/>
              <line x1="20" y1="9" x2="23" y2="9"/>
              <line x1="20" y1="14" x2="23" y2="14"/>
              <line x1="1" y1="9" x2="4" y2="9"/>
              <line x1="1" y1="14" x2="4" y2="14"/>
            </svg>
            <span>Docker</span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="visual-col">
      <div class="letter-card">
        <div class="letter-paper">
          <div class="letter-stamp">
            <span>8年</span>
            <small>匠心</small>
          </div>
          <div class="letter-fold"></div>
          
          <div class="letter-header">
            <p class="letter-date">2026年春</p>
            <h3>致每一位开发者：</h3>
          </div>
          
          <div class="letter-body">
            <p>
              大家好，我是 smart-mqtt 的作者。
            </p>
            <p>
              这是一个我一个人维护了 <span class="emphasis">8 年</span> 的开源项目。
              从 2018 年至今，断断续续，一直在优化。
            </p>
            <p class="modest">
              我不敢说它没有 Bug，也不敢说它是世界上最好的。
              但我敢说：
            </p>
            
            <div class="promise-list">
              <div class="promise-item">
                <span class="checkmark">✓</span>
                <span>工作日 24 小时内，我本人一定回复</span>
              </div>
              <div class="promise-item">
                <span class="checkmark">✓</span>
                <span>严重 Bug 优先处理，解决不了退当年费用</span>
              </div>
              <div class="promise-item">
                <span class="checkmark">✓</span>
                <span>直接对接我，不是层层转接的客服</span>
              </div>
            </div>
          </div>
          
          <div class="letter-footer">
            <p class="closing">这就是一个个人开发者能给你的</p>
            <p class="signature-highlight">最大诚意</p>
          </div>
          
          <div class="letter-lines"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 24px 80px;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    overflow: hidden;
    isolation: isolate;
    transition: background-color 0.3s ease, color 0.3s ease;
  }
  
  /* 渐变球背景 */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }
  
  .gradient-ball {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: ballFloat 20s ease-in-out infinite;
  }
  
  /* 浅色模式下的渐变球 */
  :root[data-theme="light"] .gradient-ball {
    opacity: 0.3;
  }
  
  .ball-purple {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, #635bff 0%, transparent 70%);
    top: -200px;
    right: -100px;
  }
  
  .ball-cyan {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #00d4aa 0%, transparent 70%);
    bottom: -100px;
    left: 10%;
    animation-delay: -5s;
  }
  
  .ball-pink {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #ff6b9d 0%, transparent 70%);
    top: 40%;
    left: -50px;
    animation-delay: -10s;
  }
  
  @keyframes ballFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -30px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
  }
  
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(var(--border-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-color) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.5;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }
  
  /* 主内容区 */
  .hero-main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  /* 左侧内容 */
  .content-col {
    animation: fadeInLeft 0.8s ease-out;
  }
  
  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  .badge-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    font-size: 14px;
    color: var(--accent-primary);
    font-weight: 500;
    margin-bottom: 0;
  }
  
  .docker-badge {
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s ease;
    line-height: 1;
  }
  
  .docker-badge:hover {
    transform: scale(1.05);
  }
  
  .docker-badge img {
    height: 20px;
    width: auto;
  }
  
  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.9); }
  }
  
  .title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  
  .title-line {
    display: block;
  }
  
  .title-line:first-child {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .title-line.highlight {
    background: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cost-10 {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 900;
    padding: 0 4px;
  }

  .author-highlight {
    color: #f59e0b;
    font-weight: 800;
    padding: 0 4px;
  }

  .desc {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 2;
    margin-bottom: 32px;
    max-width: 560px;
  }

  .pain-point {
    display: inline-block;
    font-weight: 500;
  }
  
  /* 按钮 */
  .btn-group {
    display: flex;
    gap: 12px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  
  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
    color: white;
    box-shadow: 0 4px 20px rgba(99, 91, 255, 0.3);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(99, 91, 255, 0.4);
  }
  
  .btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }
  
  .btn-secondary:hover {
    background: var(--bg-secondary);
    border-color: var(--accent-primary);
  }
  
  /* 环境要求 */
  .requirements-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    padding: 12px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    flex-wrap: wrap;
  }
  
  .requirements-label {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-subtle);
    font-size: 13px;
    font-weight: 500;
  }
  
  .requirements-label svg {
    color: var(--accent-primary);
  }
  
  .requirements-items {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  
  .req-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--accent-bg);
    border-radius: 8px;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .req-item:hover {
    background: var(--accent-border);
    color: var(--text-primary);
  }
  
  .req-item svg {
    color: var(--accent-primary);
    flex-shrink: 0;
  }
  
  .os-item {
    padding: 6px 12px;
  }
  
  .os-badges {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  
  .os-badge {
    padding: 2px 8px;
    background: rgba(0, 217, 170, 0.1);
    border: 1px solid rgba(0, 217, 170, 0.2);
    border-radius: 4px;
    font-size: 11px;
    color: #00d4aa;
    font-weight: 500;
  }
  
  /* 右侧信任卡片 */
  .visual-col {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: fadeInRight 0.8s ease-out 0.2s both;
  }
  
  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  /* 信纸风格卡片 */
  .letter-card {
    width: 100%;
    max-width: 500px;
    transform: perspective(1000px) rotateY(-6deg) rotateX(3deg);
    transition: transform 0.4s ease;
  }
  
  .letter-card:hover {
    transform: perspective(1000px) rotateY(-3deg) rotateX(2deg) translateY(-8px);
  }
  
  .letter-paper {
    position: relative;
    background: linear-gradient(180deg, #fffef8 0%, #fffdf5 100%);
    border-radius: 4px 12px 12px 12px;
    padding: 44px 36px 36px;
    box-shadow: 
      0 1px 1px rgba(0, 0, 0, 0.05),
      0 4px 8px rgba(0, 0, 0, 0.05),
      0 16px 40px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  
  /* 深色模式适配 */
  :root[data-theme="dark"] .letter-paper {
    background: linear-gradient(180deg, #2a2a35 0%, #252530 100%);
  }
  
  /* 邮戳装饰 */
  .letter-stamp {
    position: absolute;
    top: 24px;
    right: 28px;
    width: 56px;
    height: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px solid #d44444;
    border-radius: 50%;
    color: #d44444;
    transform: rotate(-12deg);
    opacity: 0.8;
  }
  
  .letter-stamp span {
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
  }
  
  .letter-stamp small {
    font-size: 10px;
    font-weight: 600;
    margin-top: 2px;
  }
  
  /* 折角效果 */
  .letter-fold {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 32px 32px 0 0;
    border-color: rgba(0, 0, 0, 0.05) transparent transparent transparent;
  }
  
  /* 信纸横线 */
  .letter-lines {
    position: absolute;
    top: 100px;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: repeating-linear-gradient(
      transparent,
      transparent 27px,
      rgba(99, 91, 255, 0.06) 27px,
      rgba(99, 91, 255, 0.06) 28px
    );
    pointer-events: none;
  }
  
  :root[data-theme="dark"] .letter-lines {
    background-image: repeating-linear-gradient(
      transparent,
      transparent 27px,
      rgba(255, 255, 255, 0.04) 27px,
      rgba(255, 255, 255, 0.04) 28px
    );
  }
  
  /* 信头 */
  .letter-header {
    margin-bottom: 20px;
  }
  
  .letter-date {
    font-size: 13px;
    color: #948c7a;
    margin: 0 0 8px 0;
    font-family: 'Georgia', serif;
    font-style: italic;
  }
  
  :root[data-theme="dark"] .letter-date {
    color: #888896;
  }
  
  .letter-header h3 {
    font-size: 20px;
    font-weight: 600;
    color: #2c2c2c;
    margin: 0;
    font-family: 'Georgia', serif;
  }
  
  :root[data-theme="dark"] .letter-header h3 {
    color: #e2e2e8;
  }
  
  /* 信正文 */
  .letter-body {
    position: relative;
    z-index: 1;
  }
  
  .letter-body p {
    font-size: 15px;
    line-height: 28px;
    color: #3a3a3a;
    margin: 0 0 12px 0;
  }
  
  :root[data-theme="dark"] .letter-body p {
    color: #d0d0d8;
  }
  
  .letter-body .emphasis {
    font-weight: 600;
    color: #635bff;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  
  .letter-body .modest {
    font-size: 14px;
    color: #6b6b6b;
    font-style: italic;
    margin-bottom: 16px;
  }
  
  :root[data-theme="dark"] .letter-body .modest {
    color: #a0a0a8;
  }
  
  /* 承诺列表 */
  .promise-list {
    margin: 20px 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  
  .promise-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.6;
    color: #4a4a4a;
  }
  
  :root[data-theme="dark"] .promise-item {
    color: #c0c0c8;
  }
  
  .checkmark {
    color: #2e7d32;
    font-weight: bold;
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  
  :root[data-theme="dark"] .checkmark {
    color: #81c784;
  }
  
  /* 信尾 */
  .letter-footer {
    margin-top: 24px;
    text-align: right;
    position: relative;
    z-index: 1;
  }
  
  .closing {
    font-size: 14px;
    color: #6b6b6b;
    margin: 0 0 4px 0;
    font-family: 'Georgia', serif;
    font-style: italic;
  }
  
  :root[data-theme="dark"] .closing {
    color: #a0a0a8;
  }
  
  .signature-highlight {
    font-size: 22px;
    font-weight: 700;
    color: #635bff;
    margin: 0;
    font-family: 'Georgia', serif;
    text-shadow: 1px 1px 0 rgba(99, 91, 255, 0.1);
  }
  
  /* 响应式 */
  @media (max-width: 1024px) {
    .hero-main {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }
    
    .visual-col {
      order: -1;
    }
    
    .desc {
      margin-left: auto;
      margin-right: auto;
    }
    
    .btn-group {
      justify-content: center;
    }
    
    .requirements-bar {
      justify-content: center;
    }
    
    .letter-card {
      max-width: 440px;
      transform: none;
    }
    
    .letter-card:hover {
      transform: translateY(-5px);
    }
    
  }
  
  @media (max-width: 640px) {
    .hero-section {
      padding: 100px 16px 60px;
    }
    
    .title {
      font-size: 32px;
    }
    
    .btn-group {
      flex-direction: column;
      align-items: stretch;
    }
    
    .btn-primary,
    .btn-secondary {
      justify-content: center;
    }
    
    .requirements-bar {
      flex-direction: column;
      gap: 12px;
    }
    
    .requirements-items {
      justify-content: center;
    }
    
    .letter-card {
      max-width: 100%;
      transform: none;
    }
    
    .letter-paper {
      padding: 36px 24px 28px;
    }
    
    .letter-stamp {
      top: 18px;
      right: 20px;
      width: 48px;
      height: 48px;
    }
    
    .letter-stamp span {
      font-size: 12px;
    }
    
    .letter-stamp small {
      font-size: 9px;
    }
    
    .letter-header h3 {
      font-size: 18px;
    }
    
    .letter-body p,
    .promise-item {
      font-size: 14px;
    }
    
    .signature-highlight {
      font-size: 18px;
    }
  }
</style>
