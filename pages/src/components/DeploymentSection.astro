---
---

<section class="deployment-section" id="deployment">
  <div class="deployment-container">
    <div class="deployment-header">
      <span class="deployment-tag">快速部署</span>
      <h2 class="deployment-title">选择适合你的部署方式</h2>
      <p class="deployment-description">
        提供 Docker 和手动部署两种方式，5 分钟内即可启动服务
      </p>
    </div>

    <div class="deployment-tabs">
      <div class="tab-header">
        <button class="tab-btn active" data-tab="docker">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M13.983 11.078h2.119a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.119a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 00.186-.186V3.574a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.186m0 2.716h2.118a.187.187 0 00.186-.186V6.29a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 00.184-.186V6.29a.185.185 0 00-.185-.185H8.1a.185.185 0 00-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 00.185-.186V6.29a.185.185 0 00-.185-.185H5.136a.186.186 0 00-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 00.185-.185V9.006a.185.185 0 00-.184-.186h-2.12a.186.186 0 00-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 00-.75.748 11.376 11.376 0 00.692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 00.824-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288Z"/>
          </svg>
          Docker 部署（推荐）
        </button>
        <button class="tab-btn" data-tab="manual">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
          手动部署
        </button>
      </div>

      <div class="tab-content">
        <!-- Docker 部署 -->
        <div class="tab-panel active" id="docker-panel">
          <div class="method-cards">
            <div class="method-card">
              <div class="method-header">
                <span class="method-number">01</span>
                <h3>使用 Docker Compose</h3>
              </div>
              <p class="method-desc">最简单的部署方式，一键启动完整服务</p>
              <div class="code-block">
                <div class="code-header">
                  <span>docker-compose.yaml</span>
                  <button class="copy-btn" data-code="version: '3.8'&#10;services:&#10;  smart-mqtt:&#10;    image: smartboot/smart-mqtt:latest&#10;    container_name: smart-mqtt&#10;    ports:&#10;      - 1883:1883&#10;      - 18083:18083">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    复制
                  </button>
                </div>
                <pre class="code-content"><code>version: '3.8'
services:
  smart-mqtt:
    image: smartboot/smart-mqtt:latest
    container_name: smart-mqtt
    ports:
      - 1883:1883
      - 18083:18083</code></pre>
              </div>
              <div class="command-block">
                <span class="command-prompt">$</span>
                <code>docker-compose up -d</code>
                <button class="copy-btn" data-code="docker-compose up -d">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="method-card">
              <div class="method-header">
                <span class="method-number">02</span>
                <h3>直接运行 Docker</h3>
              </div>
              <p class="method-desc">快速启动单个容器</p>
              <div class="code-block">
                <div class="code-header">
                  <span>终端命令</span>
                  <button class="copy-btn" data-code="docker run -d --name smart-mqtt -p 1883:1883 -p 18083:18083 smartboot/smart-mqtt:latest">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    复制
                  </button>
                </div>
                <pre class="code-content"><code>docker run -d \
  --name smart-mqtt \
  -p 1883:1883 \
  -p 18083:18083 \
  smartboot/smart-mqtt:latest</code></pre>
              </div>
              <div class="port-info">
                <div class="port-item">
                  <span class="port-label">1883</span>
                  <span class="port-desc">MQTT 协议端口</span>
                </div>
                <div class="port-item">
                  <span class="port-label">18083</span>
                  <span class="port-desc">Dashboard 端口</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 手动部署 -->
        <div class="tab-panel" id="manual-panel">
          <div class="method-cards">
            <div class="method-card">
              <div class="method-header">
                <span class="method-number">01</span>
                <h3>下载发行包</h3>
              </div>
              <p class="method-desc">从 Gitee 或 GitHub Releases 下载最新版本</p>
              <div class="code-block">
                <div class="code-header">
                  <span>下载并解压</span>
                  <button class="copy-btn" data-code="wget https://gitee.com/smartboot/smart-mqtt/releases/download/v1.5.2/smart-mqtt-full-master.zip\nunzip smart-mqtt-full-master.zip\ncd smart-mqtt-full-master">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    复制
                  </button>
                </div>
                <pre class="code-content"><code>wget https://gitee.com/smartboot/smart-mqtt/releases/download/v1.5.2/smart-mqtt-full-master.zip
unzip smart-mqtt-full-master.zip
cd smart-mqtt-full-master</code></pre>
              </div>
              <div class="download-links">
                <a href="https://gitee.com/smartboot/smart-mqtt/releases" target="_blank" rel="noopener" class="download-link">
                  <svg width="16" height="16" viewBox="0 0 1024 1024">
                    <path fill="currentColor" d="M512 1024q-104 0-199-40-92-39-163-110T40 711Q0 616 0 512t40-199Q79 221 150 150T313 40q95-40 199-40t199 40q92 39 163 110t110 163q40 95 40 199t-40 199q-39 92-110 163T711 984q-95 40-199 40z m259-569H480q-10 0-17.5 7.5T455 480v64q0 10 7.5 17.5T480 569h177q11 0 18.5 7.5T683 594v13q0 31-22.5 53.5T607 683H367q-11 0-18.5-7.5T341 657V417q0-31 22.5-53.5T417 341h354q11 0 18-7t7-18v-63q0-11-7-18t-18-7H417q-38 0-72.5 14T283 283q-27 27-41 61.5T228 417v354q0 11 7 18t18 7h373q46 0 85.5-22.5t62-62Q796 672 796 626V480q0-10-7-17.5t-18-7.5z"/>
                  </svg>
                  Gitee Releases
                </a>
                <a href="https://github.com/smartboot/smart-mqtt/releases" target="_blank" rel="noopener" class="download-link">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub Releases
                </a>
              </div>
            </div>

            <div class="method-card">
              <div class="method-header">
                <span class="method-number">02</span>
                <h3>启动服务</h3>
              </div>
              <p class="method-desc">执行启动脚本运行 smart-mqtt</p>
              <div class="code-block">
                <div class="code-header">
                  <span>启动命令</span>
                  <button class="copy-btn" data-code="./bin/start.sh">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    复制
                  </button>
                </div>
                <pre class="code-content"><code>./bin/start.sh</code></pre>
              </div>
              <div class="note-box">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="16" x2="12" y2="12"/>
                  <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
                <span>确保已安装 JDK 8 或更高版本</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Tab switching
  document.querySelectorAll('.deployment-section .tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.deployment-section');
      section.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      section.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      
      btn.classList.add('active');
      const panel = section.querySelector('#' + btn.dataset.tab + '-panel');
      if (panel) panel.classList.add('active');
    });
  });

  // Copy functionality
  document.querySelectorAll('.deployment-section .copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.dataset.code;
      if (code) {
        navigator.clipboard.writeText(code).then(() => {
          const originalText = btn.innerHTML;
          btn.innerHTML = `
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            已复制
          `;
          setTimeout(() => {
            btn.innerHTML = originalText;
          }, 2000);
        });
      }
    });
  });
</script>

<style>
  .deployment-section {
    padding: 100px 24px;
    background: var(--bg-primary);
    position: relative;
    transition: background-color 0.3s ease;
  }

  .deployment-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .deployment-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .deployment-tag {
    display: inline-block;
    padding: 8px 16px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    color: var(--accent-primary);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .deployment-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .deployment-description {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .deployment-tabs {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    overflow: hidden;
  }

  .tab-header {
    display: flex;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-tertiary);
  }

  .tab-btn {
    flex: 1;
    padding: 16px 24px;
    background: transparent;
    border: none;
    color: var(--text-subtle);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s ease;
    position: relative;
  }

  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    transition: background 0.2s;
  }

  .tab-btn:hover {
    color: var(--text-muted);
    background: var(--bg-secondary);
  }

  .tab-btn.active {
    color: var(--text-primary);
    background: var(--accent-bg);
  }

  .tab-btn.active::after {
    background: var(--accent-primary);
  }

  .tab-content {
    padding: 24px;
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .method-cards {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .method-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 24px;
  }

  .method-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .method-number {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .method-header h3 {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .method-desc {
    color: var(--text-subtle);
    font-size: 14px;
    margin-bottom: 16px;
    margin-left: 40px;
  }

  .code-block {
    background: var(--bg-code);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  /* 浅色模式下代码块使用深色背景 */
  :root[data-theme="light"] .code-block {
    background: #1e1e2e;
  }

  .code-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .code-header span {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 500;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 6px;
    color: var(--accent-primary);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    background: var(--accent-border);
  }

  .code-content {
    padding: 16px;
    margin: 0;
    overflow-x: auto;
  }

  .code-content code {
    font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    white-space: pre;
  }

  .command-block {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--bg-code);
    border: 1px solid var(--border-color);
    border-radius: 10px;
  }

  :root[data-theme="light"] .command-block {
    background: #1e1e2e;
  }

  .command-prompt {
    color: #00d4aa;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
  }

  .command-block code {
    flex: 1;
    font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.85);
  }

  .port-info {
    display: flex;
    gap: 16px;
    margin-top: 12px;
    padding: 12px 16px;
    background: var(--accent-bg);
    border-radius: 10px;
  }

  .port-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .port-label {
    padding: 4px 10px;
    background: var(--accent-border);
    border-radius: 6px;
    color: var(--accent-primary);
    font-size: 13px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
  }

  .port-desc {
    color: var(--text-subtle);
    font-size: 13px;
  }

  .download-links {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  .download-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .download-link:hover {
    background: var(--accent-bg);
    border-color: var(--accent-border);
    color: var(--text-primary);
  }

  .note-box {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(0, 212, 170, 0.08);
    border: 1px solid rgba(0, 212, 170, 0.15);
    border-radius: 10px;
    margin-top: 12px;
  }

  .note-box svg {
    color: var(--accent-success);
    flex-shrink: 0;
  }

  .note-box span {
    color: var(--text-muted);
    font-size: 13px;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .deployment-section {
      padding: 60px 16px;
    }

    .tab-header {
      flex-direction: column;
    }

    .tab-btn {
      justify-content: flex-start;
      padding: 14px 20px;
    }

    .tab-btn::after {
      display: none;
    }

    .tab-btn.active {
      border-left: 3px solid var(--accent-primary);
    }

    .method-desc {
      margin-left: 0;
    }

    .port-info {
      flex-direction: column;
      gap: 8px;
    }

    .download-links {
      flex-direction: column;
    }

    .deployment-title {
      font-size: 24px;
    }
  }
</style>
