  <style>
    .pricing-section {
      padding: 80px 24px;
      background: var(--bg-primary);
      transition: background-color 0.3s ease;
    }
    
    .section-container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .section-header {
      text-align: center;
      margin-bottom: 60px;
    }
    
    .section-header h2 {
      font-size: 36px;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 12px;
      background: var(--gradient-text);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .subtitle {
      color: var(--text-muted);
      font-size: 18px;
    }
    
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 40px;
    }
    
    .pricing-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      padding: 32px;
      position: relative;
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
    }
    
    .pricing-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-xl);
    }
    
    .pricing-card.featured {
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 1px var(--accent-primary), var(--shadow-lg);
    }
    
    .card-badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--gradient-accent);
      color: white;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    
    .card-header {
      margin-bottom: 24px;
    }
    
    .card-header h3 {
      font-size: 20px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 16px;
    }
    
    .price-wrap {
      display: flex;
      align-items: baseline;
      gap: 4px;
      margin-bottom: 4px;
    }
    
    .currency {
      color: var(--text-muted);
      font-size: 18px;
      font-weight: 500;
    }
    
    .price {
      font-size: 48px;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
    }
    
    .price-semi-blur {
      filter: blur(5px);
      user-select: none;
      cursor: default;
      position: relative;
      transition: filter 0.3s ease;
    }
    
    .price-semi-blur::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        45deg,
        var(--accent-primary) 0%,
        transparent 35%,
        transparent 65%,
        var(--accent-secondary) 100%
      );
      opacity: 0.25;
      mix-blend-mode: overlay;
    }
    
    .pricing-card:hover .price-semi-blur {
      filter: blur(4.5px);
    }
    
    .price-blur {
      font-size: 48px;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
      filter: blur(8px);
      user-select: none;
      cursor: default;
      position: relative;
    }
    
    .price-blur::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        45deg,
        var(--accent-primary) 0%,
        transparent 30%,
        transparent 70%,
        var(--accent-secondary) 100%
      );
      opacity: 0.3;
      mix-blend-mode: overlay;
    }
    
    .pricing-card.custom-plan {
      background: var(--accent-bg);
      border-color: var(--accent-border);
    }
    
    .pricing-card.custom-plan:hover .price-blur {
      filter: blur(10px);
    }
    
    .period {
      color: var(--text-muted);
      font-size: 14px;
    }
    
    .price-desc {
      color: var(--text-muted);
      font-size: 13px;
    }
    
    .features-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 32px;
    }
    
    .feature-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      color: var(--text-secondary);
    }
    
    .feature-item.highlight {
      color: var(--accent-primary);
      font-weight: 500;
    }
    
    .check {
      width: 18px;
      height: 18px;
      color: var(--accent-success);
      flex-shrink: 0;
    }
    
    .feature-item.highlight .check {
      color: var(--accent-primary);
    }
    
    .card-footer-note {
      text-align: center;
      font-size: 12px;
      color: var(--text-muted);
      margin: 0;
      padding-top: 12px;
      border-top: 1px solid var(--border-color);
    }
    
    .unified-contact {
      max-width: 520px;
      margin: 0 auto 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 24px;
      background: var(--gradient-card);
      border: 1px solid var(--accent-border);
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .unified-contact:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
      border-color: var(--accent-primary);
    }
    
    .unified-contact:hover .contact-arrow {
      transform: translateX(4px);
      color: var(--accent-primary);
    }
    
    .contact-icon-group {
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--gradient-accent);
      border-radius: 12px;
      flex-shrink: 0;
    }
    
    .contact-icon {
      width: 24px;
      height: 24px;
      color: white;
    }
    
    .contact-text {
      text-align: left;
      flex: 1;
    }
    
    .contact-line1 {
      font-size: 14px;
      color: var(--text-muted);
      margin: 0 0 4px;
    }
    
    .contact-line2 {
      font-size: 16px;
      color: var(--text-primary);
      margin: 0;
    }
    
    .contact-line2 strong {
      color: var(--accent-primary);
      font-weight: 700;
    }
    
    .contact-arrow {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      transition: all 0.3s ease;
      flex-shrink: 0;
    }
    
    .contact-arrow svg {
      width: 20px;
      height: 20px;
    }
    
    /* 弹窗样式 */
    .qr-modal {
      position: fixed;
      inset: 0;
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    
    .qr-modal.active {
      display: flex;
    }
    
    .qr-modal-overlay {
      position: absolute;
      inset: 0;
      background: var(--overlay-bg);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      animation: overlayFadeIn 0.3s ease;
    }
    
    @keyframes overlayFadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    
    .qr-modal-content {
      position: relative;
      background: var(--bg-card);
      border: 1px solid var(--accent-border);
      border-radius: 24px;
      padding: 40px 32px 32px;
      text-align: center;
      max-width: 340px;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      animation: modalSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      box-shadow: var(--shadow-xl);
    }
    
    :root[data-theme="light"] .qr-modal-content {
      background: #ffffff;
    }
    
    :root[data-theme="dark"] .qr-modal-content {
      background: linear-gradient(145deg, #1e1e2a 0%, #12121a 100%);
    }
    
    @keyframes modalSlideIn {
      from {
        opacity: 0;
        transform: scale(0.8) translateY(20px);
      }
      to {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }
    
    .qr-modal-close {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      color: var(--text-muted);
      transition: all 0.2s ease;
    }
    
    .qr-modal-close:hover {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }
    
    .qr-modal-header {
      margin-bottom: 20px;
    }
    
    .qr-modal-icon {
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--gradient-accent);
      border-radius: 16px;
      margin: 0 auto 16px;
      color: white;
    }
    
    .qr-modal-header h3 {
      font-size: 20px;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0 0 6px;
    }
    
    .qr-modal-header p {
      font-size: 14px;
      color: var(--text-muted);
      margin: 0;
    }
    
    .qr-image-wrap {
      position: relative;
      background: white;
      border-radius: 12px;
      padding: 16px;
      margin: 0 auto 20px;
      max-width: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .qr-image {
      width: 100%;
      height: auto;
      border-radius: 8px;
      display: block;
      max-width: 188px;
    }
    
    .qr-loading {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 12px;
      transition: opacity 0.3s ease;
    }
    
    .qr-loading.hidden {
      opacity: 0;
      pointer-events: none;
    }
    
    .qr-loading-spinner {
      width: 40px;
      height: 40px;
      border: 3px solid #e0e0e0;
      border-top-color: var(--accent-primary);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    .qr-modal-footer {
      padding-top: 16px;
      border-top: 1px solid var(--border-color);
    }
    
    .qr-modal-tip {
      color: var(--text-subtle);
      font-size: 12px;
      margin: 0;
    }
    
    .pricing-note {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 20px;
      background: var(--accent-bg);
      border: 1px solid var(--accent-border);
      border-radius: 12px;
      color: var(--text-secondary);
      font-size: 14px;
    }
    
    .pricing-note svg {
      width: 20px;
      height: 20px;
      color: var(--accent-primary);
      flex-shrink: 0;
    }
    
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 24px;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      border: none;
    }
    
    .btn-primary {
      background: var(--gradient-accent);
      color: white;
      box-shadow: 0 4px 14px 0 rgba(99, 91, 255, 0.4);
    }
    
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px 0 rgba(99, 91, 255, 0.5);
    }
    
    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
    }
    
    .btn-secondary:hover {
      background: var(--border-color);
    }
    
    @media (max-width: 1024px) {
      .pricing-grid {
        grid-template-columns: 1fr;
        max-width: 400px;
        margin: 0 auto 40px;
      }
      
      .pricing-card.featured {
        order: -1;
      }
    }
    
    @media (max-width: 768px) {
      .pricing-section {
        padding: 60px 16px;
      }
      
      .section-header h2 {
        font-size: 28px;
      }
      
      .pricing-card {
        padding: 24px;
      }
    }
  </style>
  
  <script>
    const openQrContact = document.getElementById('openQrContact');
    const modal = document.getElementById('qrPricingModal');
    const closeBtn = document.getElementById('qrPricingModalClose');
    const qrImage = document.getElementById('pricingQrImage');
    const qrLoading = document.getElementById('pricingQrLoading');

    const openModal = () => {
      if (modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        if (qrLoading && !qrLoading.classList.contains('hidden')) {
          qrLoading.classList.remove('hidden');
        }
      }
    };

    if (openQrContact) {
      openQrContact.addEventListener('click', openModal);
    }

    if (modal && closeBtn) {
      closeBtn.addEventListener('click', () => {
        modal.classList.remove('active');
        document.body.style.overflow = '';
      });

      modal.querySelector('.qr-modal-overlay')?.addEventListener('click', () => {
        modal.classList.remove('active');
        document.body.style.overflow = '';
      });

      if (qrImage) {
        if (qrImage.complete) {
          qrLoading?.classList.add('hidden');
        } else {
          qrImage.addEventListener('load', () => {
            qrLoading?.classList.add('hidden');
          });
        }
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        }
      });
    }
  </script>
</section>
