---
---

<section class="verification-section" id="verification">
  <div class="verification-container">
    <div class="verification-header">
      <span class="verification-tag">Verify Deployment</span>
      <h2 class="verification-title">Verify Service Running Status</h2>
      <p class="verification-description">
        Multiple ways to verify if smart-mqtt is running successfully
      </p>
    </div>

    <div class="verification-grid">
      <div class="verify-card">
        <div class="verify-header">
          <div class="verify-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3>Check Service Status</h3>
        </div>
        
        <div class="verify-steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <p class="step-title">View Process</p>
              <div class="code-block">
                <code>ps aux | grep smart-mqtt</code>
                <button class="copy-btn" data-code="ps aux | grep smart-mqtt">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <p class="step-title">Check Port Listening</p>
              <div class="code-block">
                <code>netstat -tlnp | grep 1883</code>
                <button class="copy-btn" data-code="netstat -tlnp | grep 1883">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="verify-card">
        <div class="verify-header">
          <div class="verify-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>MQTT Client Test</h3>
        </div>
        
        <div class="verify-steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <p class="step-title">Subscribe to Topic (Terminal 1)</p>
              <div class="code-block">
                <code>mosquitto_sub -h localhost -p 1883 -t test/topic</code>
                <button class="copy-btn" data-code="mosquitto_sub -h localhost -p 1883 -t test/topic">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <p class="step-title">Publish Message (Terminal 2)</p>
              <div class="code-block">
                <code>mosquitto_pub -h localhost -p 1883 -t test/topic -m "Hello"</code>
                <button class="copy-btn" data-code='mosquitto_pub -h localhost -p 1883 -t test/topic -m "Hello"'>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="client-links">
          <span>Recommended Clients:</span>
          <a href="https://mqttx.app/" target="_blank" rel="noopener" class="client-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            MQTT X
          </a>
          <span class="divider">|</span>
          <span class="client-text">Command line tool mosquitto</span>
        </div>
      </div>

      <div class="verify-card wide">
        <div class="verify-header">
          <div class="verify-icon dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
          </div>
          <h3>Access Dashboard (Enterprise Edition)</h3>
        </div>
        
        <div class="dashboard-content">
          <div class="dashboard-url">
            <span class="url-label">Access URL</span>
            <a href="http://localhost:18083" target="_blank" rel="noopener" class="url-link">
              http://localhost:18083
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
          
          <div class="credentials">
            <div class="credential-item">
              <span class="credential-label">Default Username</span>
              <code class="credential-value">smart-mqtt</code>
            </div>
            <div class="credential-item">
              <span class="credential-label">Default Password</span>
              <code class="credential-value">smart-mqtt</code>
            </div>
          </div>

          <div class="security-note">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>For security reasons, please change to a stronger password in production environment</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.verification-section .copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.dataset.code;
      if (code) {
        navigator.clipboard.writeText(code).then(() => {
          const originalHTML = btn.innerHTML;
          btn.innerHTML = `
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          `;
          setTimeout(() => {
            btn.innerHTML = originalHTML;
          }, 2000);
        });
      }
    });
  });
</script>

<style>
  .verification-section {
    padding: 100px 24px;
    background: var(--bg-secondary);
    position: relative;
    transition: background-color 0.3s ease;
  }

  .verification-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .verification-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .verification-tag {
    display: inline-block;
    padding: 8px 16px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    color: var(--accent-primary);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .verification-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .verification-description {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .verification-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .verify-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 28px;
    transition: all 0.3s ease;
  }

  .verify-card:hover {
    border-color: var(--accent-border);
    box-shadow: var(--shadow-lg);
  }

  .verify-card.wide {
    grid-column: span 2;
  }

  .verify-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .verify-icon {
    width: 44px;
    height: 44px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-primary);
  }

  .verify-icon svg {
    width: 22px;
    height: 22px;
  }

  .verify-icon.dashboard {
    background: rgba(0, 212, 170, 0.1);
    border-color: rgba(0, 212, 170, 0.2);
    color: var(--accent-success);
  }

  .verify-header h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .verify-steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .step {
    display: flex;
    gap: 16px;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 50%;
    color: var(--accent-primary);
    font-size: 14px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .code-block {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--bg-code);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 13px;
  }

  .code-block code {
    flex: 1;
    color: var(--text-secondary);
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    background: transparent;
    border: none;
    color: var(--text-subtle);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .copy-btn:hover {
    color: var(--accent-primary);
  }

  .client-links {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color-light);
    font-size: 13px;
    color: var(--text-muted);
  }

  .client-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--accent-primary);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .client-link:hover {
    opacity: 0.8;
  }

  .divider {
    color: var(--text-subtle);
  }

  .client-text {
    color: var(--text-subtle);
  }

  .dashboard-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .dashboard-url {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .url-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    min-width: 100px;
  }

  .url-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    color: var(--accent-primary);
    text-decoration: none;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .url-link:hover {
    background: var(--accent-primary);
    color: white;
  }

  .credentials {
    display: flex;
    gap: 24px;
  }

  .credential-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .credential-label {
    font-size: 14px;
    color: var(--text-muted);
  }

  .credential-value {
    padding: 6px 12px;
    background: var(--bg-code);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .security-note {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(255, 193, 7, 0.1);
    border: 1px solid rgba(255, 193, 7, 0.2);
    border-radius: 10px;
    color: var(--text-secondary);
    font-size: 13px;
    line-height: 1.5;
  }

  .security-note svg {
    color: var(--accent-warning);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .verification-grid {
      grid-template-columns: 1fr;
    }

    .verify-card.wide {
      grid-column: span 1;
    }

    .credentials {
      flex-direction: column;
      gap: 12px;
    }

    .dashboard-url {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
