        <span>Visit GitHub</span>
      </a>
      <a href="https://gitee.com/smartboot/smart-mqtt" class="btn-secondary btn-large" target="_blank" rel="noopener">
        <svg viewBox="0 0 1024 1024" width="20" height="20">
          <path fill="currentColor" d="M512 1024q-104 0-199-40-92-39-163-110T40 711Q0 616 0 512t40-199Q79 221 150 150T313 40q95-40 199-40t199 40q92 39 163 110t110 163q40 95 40 199t-40 199q-39 92-110 163T711 984q-95 40-199 40z m259-569H480q-10 0-17.5 7.5T455 480v64q0 10 7.5 17.5T480 569h177q11 0 18.5 7.5T683 594v13q0 31-22.5 53.5T607 683H367q-11 0-18.5-7.5T341 657V417q0-31 22.5-53.5T417 341h354q11 0 18-7t7-18v-63q0-11-7-18t-18-7H417q-38 0-72.5 14T283 283q-27 27-41 61.5T228 417v354q0 11 7 18t18 7h373q46 0 85.5-22.5t62-62Q796 672 796 626V480q0-10-7-17.5t-18-7.5z"/>
        </svg>
        <span>Visit Gitee</span>
      </a>
    </div>
  </div>
</section>

<style>
  .enterprise-section {
    padding: 100px 24px;
    background: var(--bg-secondary);
    position: relative;
    transition: background-color 0.3s ease;
  }

  .enterprise-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .enterprise-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .enterprise-tag {
    display: inline-block;
    padding: 8px 16px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    color: var(--accent-primary);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .enterprise-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .enterprise-description {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .enterprise-features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  @media (max-width: 1024px) {
    .enterprise-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .enterprise-features {
      grid-template-columns: 1fr;
    }
  }

  .enterprise-feature {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 28px;
    text-align: center;
    transition: all 0.3s ease;
  }

  .enterprise-feature:hover {
    border-color: var(--accent-border);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .feature-icon {
    width: 56px;
    height: 56px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: var(--accent-primary);
  }

  .feature-icon svg {
    width: 28px;
    height: 28px;
  }

  .enterprise-feature h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .enterprise-feature p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .enterprise-cta {
    text-align: center;
  }

  .btn-enterprise {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background: var(--gradient-accent);
    border: none;
    border-radius: 12px;
    color: white;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-enterprise:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(99, 91, 255, 0.3);
  }

  .contact-email {
    margin-top: 16px;
    font-size: 14px;
    color: var(--text-muted);
  }

  .cta-section {
    padding: 120px 24px;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  .cta-bg-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: var(--accent-primary);
    top: -100px;
    right: -100px;
  }

  .orb-2 {
    width: 300px;
    height: 300px;
    background: var(--accent-secondary);
    bottom: -50px;
    left: -50px;
  }

  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(var(--border-color-light) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-color-light) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.5;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .cta-description {
    font-size: 20px;
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    color: var(--text-secondary);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: var(--accent-border);
    color: var(--accent-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .btn-large {
    padding: 16px 32px;
    font-size: 16px;
  }
</style>
