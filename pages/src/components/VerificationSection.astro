---
---

<section class="verification-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">验证部署</span>
      <h2 class="section-title">验证服务运行状态</h2>
      <p class="section-description">
        通过多种方式验证 smart-mqtt 是否成功运行
      </p>
    </div>

    <div class="verification-grid">
      <div class="verify-card">
        <div class="verify-header">
          <div class="verify-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3>检查服务状态</h3>
        </div>
        
        <div class="verify-steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <p class="step-title">查看进程</p>
              <div class="code-block">
                <code>ps aux | grep smart-mqtt</code>
                <button class="copy-btn" onclick="copyCode(this)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <p class="step-title">查看端口监听</p>
              <div class="code-block">
                <code>netstat -tlnp | grep 1883</code>
                <button class="copy-btn" onclick="copyCode(this)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="verify-card">
        <div class="verify-header">
          <div class="verify-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>MQTT 客户端测试</h3>
        </div>
        
        <div class="verify-steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <p class="step-title">订阅主题（终端 1）</p>
              <div class="code-block">
                <code>mosquitto_sub -h localhost -p 1883 -t test/topic</code>
                <button class="copy-btn" onclick="copyCode(this)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <p class="step-title">发布消息（终端 2）</p>
              <div class="code-block">
                <code>mosquitto_pub -h localhost -p 1883 -t test/topic -m "Hello smart-mqtt"</code>
                <button class="copy-btn" onclick="copyCode(this)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="client-links">
          <span>推荐客户端：</span>
          <a href="https://mqttx.app/" target="_blank" class="client-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            MQTT X
          </a>
          <span class="divider">|</span>
          <span class="client-text">命令行工具 mosquitto</span>
        </div>
      </div>

      <div class="verify-card wide">
        <div class="verify-header">
          <div class="verify-icon dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
          </div>
          <h3>访问 Dashboard（企业版）</h3>
        </div>
        
        <div class="dashboard-content">
          <div class="dashboard-url">
            <span class="url-label">访问地址</span>
            <a href="http://localhost:8083" target="_blank" class="url-link">
              http://localhost:8083
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
          
          <div class="credentials">
            <div class="credential-item">
              <span class="credential-label">默认账号</span>
              <code class="credential-value">smart-mqtt</code>
            </div>
            <div class="credential-item">
              <span class="credential-label">默认密码</span>
              <code class="credential-value">smart-mqtt</code>
            </div>
          </div>

          <div class="security-note">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>出于安全考虑，生产环境请尽快修改成安全性更高的密码</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function copyCode(btn) {
    const code = btn.previousElementSibling.textContent;
    navigator.clipboard.writeText(code).then(() => {
      const originalHTML = btn.innerHTML;
      btn.innerHTML = `
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      `;
      setTimeout(() => {
        btn.innerHTML = originalHTML;
      }, 2000);
    });
  }
</script>

<style>
  .verification-section {
    padding: 5rem 1.5rem;
    background: var(--sl-color-bg);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-tag {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--sl-color-bg-inline-code);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 9999px;
    color: var(--sl-color-accent);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--sl-color-text);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .section-description {
    font-size: 1.125rem;
    color: var(--sl-color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .verification-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .verify-card {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: all 0.2s ease;
  }

  .verify-card:hover {
    border-color: var(--sl-color-accent);
  }

  .verify-card.wide {
    grid-column: span 2;
  }

  .verify-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }

  .verify-icon {
    width: 36px;
    height: 36px;
    background: var(--sl-color-accent-low);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sl-color-accent);
  }

  .verify-icon.dashboard {
    background: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
  }

  .verify-icon svg {
    width: 18px;
    height: 18px;
  }

  .verify-header h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .verify-steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step {
    display: flex;
    gap: 0.625rem;
  }

  .step-number {
    width: 22px;
    height: 22px;
    background: var(--sl-color-accent-low);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-accent);
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
    min-width: 0;
  }

  .step-title {
    font-size: 0.8125rem;
    color: var(--sl-color-text-muted);
    margin-bottom: 0.375rem;
  }

  .code-block {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    background: var(--sl-color-bg-inline-code);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
  }

  .code-block code {
    flex: 1;
    color: var(--sl-color-text);
    overflow-x: auto;
    white-space: nowrap;
  }

  .copy-btn {
    padding: 0.25rem;
    background: transparent;
    border: none;
    color: var(--sl-color-text-muted);
    cursor: pointer;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    color: var(--sl-color-text);
  }

  .client-links {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 0.8125rem;
    color: var(--sl-color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .client-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--sl-color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  .client-link:hover {
    color: var(--sl-color-accent-high);
  }

  .divider {
    color: var(--sl-color-hairline);
  }

  .client-text {
    color: var(--sl-color-text-muted);
  }

  .dashboard-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .dashboard-url {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .url-label {
    font-size: 0.8125rem;
    color: var(--sl-color-text-muted);
  }

  .url-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    background: var(--sl-color-orange-low);
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.375rem;
    color: var(--sl-color-orange-high);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    font-weight: 500;
    transition: all 0.2s;
    width: fit-content;
  }

  .url-link:hover {
    background: var(--sl-color-orange);
    color: var(--sl-color-text-invert);
  }

  .credentials {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .credential-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .credential-label {
    font-size: 0.8125rem;
    color: var(--sl-color-text-muted);
    min-width: 70px;
  }

  .credential-value {
    padding: 0.3125rem 0.625rem;
    background: var(--sl-color-bg-inline-code);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.25rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--sl-color-text);
  }

  .security-note {
    grid-column: span 2;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: var(--sl-color-orange-low);
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.375rem;
    color: var(--sl-color-orange-high);
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .verification-section {
      padding: 3rem 1rem;
    }

    .verification-grid {
      grid-template-columns: 1fr;
    }

    .verify-card.wide {
      grid-column: span 1;
    }

    .dashboard-content {
      grid-template-columns: 1fr;
    }

    .security-note {
      grid-column: span 1;
    }
  }
</style>
