---
---

<section class="verification-section">
  <div class="verification-container">
    <div class="verification-header">
      <span class="verification-tag">验证部署</span>
      <h2 class="verification-title">验证服务运行状态</h2>
      <p class="verification-description">
        通过多种方式验证 smart-mqtt 是否成功运行
      </p>
    </div>

    <div class="verification-grid">
      <!-- 检查服务状态 -->
      <div class="verify-card">
        <div class="verify-header">
          <div class="verify-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3>检查服务状态</h3>
        </div>
        
        <div class="verify-steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <p class="step-title">查看进程</p>
              <div class="code-block">
                <code>ps aux | grep smart-mqtt</code>
                <button class="copy-btn" data-code="ps aux | grep smart-mqtt">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <p class="step-title">查看端口监听</p>
              <div class="code-block">
                <code>netstat -tlnp | grep 1883</code>
                <button class="copy-btn" data-code="netstat -tlnp | grep 1883">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- MQTT 客户端测试 -->
      <div class="verify-card">
        <div class="verify-header">
          <div class="verify-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>MQTT 客户端测试</h3>
        </div>
        
        <div class="verify-steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <p class="step-title">订阅主题（终端 1）</p>
              <div class="code-block">
                <code>mosquitto_sub -h localhost -p 1883 -t test/topic</code>
                <button class="copy-btn" data-code="mosquitto_sub -h localhost -p 1883 -t test/topic">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <p class="step-title">发布消息（终端 2）</p>
              <div class="code-block">
                <code>mosquitto_pub -h localhost -p 1883 -t test/topic -m "Hello"</code>
                <button class="copy-btn" data-code='mosquitto_pub -h localhost -p 1883 -t test/topic -m "Hello"'>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="client-links">
          <span>推荐客户端：</span>
          <a href="https://mqttx.app/" target="_blank" rel="noopener" class="client-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            MQTT X
          </a>
          <span class="divider">|</span>
          <span class="client-text">命令行工具 mosquitto</span>
        </div>
      </div>

      <!-- 访问 Dashboard -->
      <div class="verify-card wide">
        <div class="verify-header">
          <div class="verify-icon dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
          </div>
          <h3>访问 Dashboard（企业版）</h3>
        </div>
        
        <div class="dashboard-content">
          <div class="dashboard-url">
            <span class="url-label">访问地址</span>
            <a href="http://localhost:18083" target="_blank" rel="noopener" class="url-link">
              http://localhost:18083
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
          
          <div class="credentials">
            <div class="credential-item">
              <span class="credential-label">默认账号</span>
              <code class="credential-value">smart-mqtt</code>
            </div>
            <div class="credential-item">
              <span class="credential-label">默认密码</span>
              <code class="credential-value">smart-mqtt</code>
            </div>
          </div>

          <div class="security-note">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>出于安全考虑，生产环境请尽快修改成安全性更高的密码</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.verification-section .copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.dataset.code;
      if (code) {
        navigator.clipboard.writeText(code).then(() => {
          const originalHTML = btn.innerHTML;
          btn.innerHTML = `
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          `;
          setTimeout(() => {
            btn.innerHTML = originalHTML;
          }, 2000);
        });
      }
    });
  });
</script>

<style>
  .verification-section {
    padding: 100px 24px;
    background: #0a0a0f;
    position: relative;
  }

  .verification-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .verification-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .verification-tag {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(99, 91, 255, 0.1);
    border: 1px solid rgba(99, 91, 255, 0.2);
    border-radius: 9999px;
    color: #635bff;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .verification-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: white;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .verification-description {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.6);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .verification-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .verify-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    padding: 28px;
    transition: all 0.3s ease;
  }

  .verify-card:hover {
    border-color: rgba(99, 91, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .verify-card.wide {
    grid-column: span 2;
  }

  .verify-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .verify-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, rgba(99, 91, 255, 0.2) 0%, rgba(99, 91, 255, 0.1) 100%);
    border: 1px solid rgba(99, 91, 255, 0.2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #635bff;
  }

  .verify-icon svg {
    width: 22px;
    height: 22px;
  }

  .verify-icon.dashboard {
    background: linear-gradient(135deg, rgba(0, 212, 170, 0.2) 0%, rgba(0, 212, 170, 0.1) 100%);
    border-color: rgba(0, 212, 170, 0.2);
    color: #00d4aa;
  }

  .verify-header h3 {
    font-size: 18px;
    font-weight: 600;
    color: white;
  }

  .verify-steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .step {
    display: flex;
    gap: 16px;
  }

  .step-number {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .code-block {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
  }

  .code-block code {
    flex: 1;
    font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
    word-break: break-all;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(99, 91, 255, 0.1);
    border: 1px solid rgba(99, 91, 255, 0.2);
    border-radius: 6px;
    color: #635bff;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: rgba(99, 91, 255, 0.2);
    border-color: rgba(99, 91, 255, 0.3);
  }

  .client-links {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.5);
    font-size: 13px;
    flex-wrap: wrap;
  }

  .client-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #635bff;
    font-weight: 500;
    transition: color 0.2s;
  }

  .client-link:hover {
    color: #8b5cf6;
  }

  .divider {
    color: rgba(255, 255, 255, 0.2);
  }

  .client-text {
    color: rgba(255, 255, 255, 0.4);
  }

  .dashboard-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .dashboard-url {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 12px;
  }

  .url-label {
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    flex-shrink: 0;
  }

  .url-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #635bff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .url-link:hover {
    color: #8b5cf6;
  }

  .credentials {
    display: flex;
    gap: 24px;
    padding: 16px 20px;
    background: rgba(99, 91, 255, 0.05);
    border: 1px solid rgba(99, 91, 255, 0.1);
    border-radius: 12px;
  }

  .credential-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .credential-label {
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
  }

  .credential-value {
    padding: 6px 12px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: white;
  }

  .security-note {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(255, 193, 7, 0.08);
    border: 1px solid rgba(255, 193, 7, 0.15);
    border-radius: 10px;
  }

  .security-note svg {
    color: #ffc107;
    flex-shrink: 0;
  }

  .security-note span {
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .verification-section {
      padding: 60px 16px;
    }

    .verification-grid {
      grid-template-columns: 1fr;
    }

    .verify-card.wide {
      grid-column: span 1;
    }

    .credentials {
      flex-direction: column;
      gap: 12px;
    }

    .verification-title {
      font-size: 24px;
    }

    .dashboard-url {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
