---
import Navbar from '../../components/en/Navbar.astro';
import Hero from '../../components/en/Hero.astro';
import LogoMarquee from '../../components/en/LogoMarquee.astro';
import FeatureCards from '../../components/en/FeatureCards.astro';
import PerformanceSection from '../../components/en/PerformanceSection.astro';
import CostAdvantageSection from '../../components/en/CostAdvantageSection.astro';
import DeploymentSection from '../../components/en/DeploymentSection.astro';
import VerificationSection from '../../components/en/VerificationSection.astro';
import CTASection from '../../components/en/CTASection.astro';
import Footer from '../../components/en/Footer.astro';
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="smart-mqtt is a commercial MQTT Broker product launched by the smartboot open-source organization, designed for enterprise-level IoT scenarios with tens of thousands of device connections.">
  <meta name="keywords" content="smart-mqtt,mqtt,broker,mqtt broker">
  <title>smart-mqtt - Enterprise IoT Message Middleware</title>
  <link rel="icon" type="image/svg+xml" href="/smart-mqtt/favicon.svg">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style is:global>
    :root {
      --accent-primary: #635bff;
      --accent-secondary: #8b5cf6;
      --accent-success: #00d4aa;
      --accent-warning: #ffc107;
      --accent-error: #ff5f56;
      
      --bg-primary: #ffffff;
      --bg-secondary: #f8fafc;
      --bg-tertiary: #f1f5f9;
      --bg-card: #ffffff;
      --bg-code: #f1f5f9;
      
      --text-primary: #0f172a;
      --text-secondary: #334155;
      --text-muted: #64748b;
      --text-subtle: #94a3b8;
      
      --border-color: #e2e8f0;
      --border-color-light: #f1f5f9;
      
      --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      
      --accent-bg: rgba(99, 91, 255, 0.08);
      --accent-border: rgba(99, 91, 255, 0.2);
      
      --gradient-text: linear-gradient(135deg, #0f172a 0%, #334155 100%);
      --gradient-accent: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
      
      --overlay-bg: rgba(0, 0, 0, 0.5);
    }
    
    :root[data-theme="dark"] {
      --bg-primary: #0a0a0f;
      --bg-secondary: #0d0d14;
      --bg-tertiary: #111119;
      --bg-card: rgba(255, 255, 255, 0.02);
      --bg-code: rgba(0, 0, 0, 0.4);
      
      --text-primary: #ffffff;
      --text-secondary: #e2e8f0;
      --text-muted: rgba(255, 255, 255, 0.7);
      --text-subtle: rgba(255, 255, 255, 0.5);
      
      --border-color: rgba(255, 255, 255, 0.06);
      --border-color-light: rgba(255, 255, 255, 0.1);
      
      --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.6);
      
      --accent-bg: rgba(99, 91, 255, 0.1);
      --accent-border: rgba(99, 91, 255, 0.2);
      
      --gradient-text: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.8) 100%);
      --gradient-accent: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
      
      --overlay-bg: rgba(0, 0, 0, 0.8);
    }
    
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--bg-primary);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      transition: background-color 0.3s ease, color 0.3s ease;
    }
    
    a {
      color: inherit;
      text-decoration: none;
    }
    
    img {
      max-width: 100%;
      height: auto;
    }
    
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    
    ::-webkit-scrollbar-track {
      background: var(--bg-primary);
    }
    
    ::-webkit-scrollbar-thumb {
      background: var(--text-subtle);
      border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: var(--text-muted);
    }
    
    ::selection {
      background: rgba(99, 91, 255, 0.3);
      color: white;
    }
  </style>
  
  <script>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const html = document.documentElement;
      
      if (savedTheme) {
        html.setAttribute('data-theme', savedTheme);
      } else if (prefersDark) {
        html.setAttribute('data-theme', 'dark');
      } else {
        html.setAttribute('data-theme', 'light');
      }
      
      localStorage.setItem('language', 'en');
      html.setAttribute('lang', 'en');
    })();
  </script>
</head>
<body>
  <Navbar />
  
  <Hero />

  <LogoMarquee />
  
  <FeatureCards />
  <CostAdvantageSection />
  <PerformanceSection />
  
  <DeploymentSection />
  
  <VerificationSection />
  
  <CTASection />
  
  <Footer />
</body>
</html>
