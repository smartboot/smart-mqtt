    function updateTranslations(lang) {
      const trans = translations[lang];
      
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const keys = key.split('.');
        let value = trans;
        
        for (const k of keys) {
          value = value[k];
          if (!value) break;
        }
        
        if (value) {
          el.textContent = value;
        }
      });
      
      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        const key = el.getAttribute('data-i18n-html');
        const keys = key.split('.');
        let value = trans;
        
        for (const k of keys) {
          value = value[k];
          if (!value) break;
        }
        
        if (value) {
          el.innerHTML = value;
        }
      });
      
      document.querySelectorAll('[data-i18n-arr]').forEach(el => {
        const arrKey = el.getAttribute('data-i18n-arr');
        const idx = parseInt(el.getAttribute('data-i18n-idx') || '0');
        const keys = arrKey.split('.');
        let value = trans;
        
        for (const k of keys) {
          value = value[k];
          if (!value) break;
        }
        
        if (Array.isArray(value) && value[idx]) {
          const roleEl = el.querySelector('.person-role');
          if (roleEl) {
            roleEl.textContent = value[idx];
          } else {
            el.textContent = value[idx];
          }
        }
      });
    }
    
    window.addEventListener('languageChange', (e) => {
      updateTranslations(e.detail.language);
    });
    
    document.addEventListener('DOMContentLoaded', () => {
      const lang = document.documentElement.getAttribute('lang') || 'zh';
      updateTranslations(lang);
    });
  </script>
