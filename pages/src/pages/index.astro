  <style>
    .custom-footer {
      background: var(--bg-primary);
      border-top: 1px solid var(--border-color);
      padding: 80px 24px 0;
      transition: background-color 0.3s ease;
    }
    
    .footer-content {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 80px;
      padding-bottom: 60px;
    }
    
    .footer-main {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    
    .footer-brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .footer-logo-icon {
      width: 36px;
      height: 36px;
    }
    
    .footer-brand-info {
      display: flex;
      flex-direction: column;
    }
    
    .footer-logo-text {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }
    
    .footer-desc {
      color: var(--text-subtle);
      font-size: 14px;
      margin-top: 2px;
    }
    
    .footer-social {
      display: flex;
      gap: 12px;
    }
    
    .footer-social a {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      color: var(--text-muted);
      transition: all 0.2s;
    }
    
    .footer-social a:hover {
      background: var(--accent-bg);
      border-color: var(--accent-primary);
      color: var(--accent-primary);
    }
    
    .footer-links {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
    }
    
    .link-column {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    .link-column h4 {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
    }
    
    .link-column a {
      color: var(--text-subtle);
      font-size: 14px;
      transition: color 0.2s;
    }
    
    .link-column a:hover {
      color: var(--accent-primary);
    }
    
    .footer-bottom {
      border-top: 1px solid var(--border-color);
      padding: 24px;
    }
    
    .footer-bottom-content {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    
    .footer-bottom p {
      color: var(--text-subtle);
      font-size: 14px;
    }
    
    .footer-stats {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .stat-item {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--text-subtle);
      font-size: 14px;
    }
    
    .stat-item svg {
      color: var(--accent-primary);
    }
    
    .stat-divider {
      width: 1px;
      height: 16px;
      background: var(--border-color);
    }
    
    @media (max-width: 1024px) {
      .footer-content {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      
      .footer-links {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (max-width: 640px) {
      .custom-footer {
        padding: 60px 16px 0;
      }
      
      .footer-content {
        padding-bottom: 40px;
      }
      
      .footer-links {
        grid-template-columns: 1fr;
        gap: 24px;
      }
      
      .footer-bottom-content {
        flex-direction: column;
        text-align: center;
      }
    }
  </style>
  
