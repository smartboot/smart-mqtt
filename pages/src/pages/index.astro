---
// 完全自定义的首页 - Stripe 风格设计，支持浅色/深色主题切换
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import FeatureCards from '../components/FeatureCards.astro';
import PerformanceSection from '../components/PerformanceSection.astro';
import DeploymentSection from '../components/DeploymentSection.astro';
import VerificationSection from '../components/VerificationSection.astro';
import CTASection from '../components/CTASection.astro';
---

<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="smart-mqtt 是 smartboot 开源组织推出的商业化 MQTT Broker 产品，专为拥有上万级设备连接量的企业级物联网场景设计。">
  <meta name="keywords" content="smart-mqtt,mqtt,broker,mqtt broker">
  <title>smart-mqtt - 企业级物联网消息中间件</title>
  <link rel="icon" type="image/svg+xml" href="/smart-mqtt/favicon.svg">
  
  <!-- Inter 字体 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style is:global>
    /* ===== 主题 CSS 变量定义 ===== */
    :root {
      /* 主题色 */
      --accent-primary: #635bff;
      --accent-secondary: #8b5cf6;
      --accent-success: #00d4aa;
      --accent-warning: #ffc107;
      --accent-error: #ff5f56;
      
      /* 浅色主题变量 */
      --bg-primary: #ffffff;
      --bg-secondary: #f8fafc;
      --bg-tertiary: #f1f5f9;
      --bg-card: #ffffff;
      --bg-code: #f1f5f9;
      
      --text-primary: #0f172a;
      --text-secondary: #334155;
      --text-muted: #64748b;
      --text-subtle: #94a3b8;
      
      --border-color: #e2e8f0;
      --border-color-light: #f1f5f9;
      
      --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      
      --accent-bg: rgba(99, 91, 255, 0.08);
      --accent-border: rgba(99, 91, 255, 0.2);
      
      --gradient-text: linear-gradient(135deg, #0f172a 0%, #334155 100%);
      --gradient-accent: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
      
      --overlay-bg: rgba(0, 0, 0, 0.5);
    }
    
    /* 深色主题变量 */
    :root[data-theme="dark"] {
      --bg-primary: #0a0a0f;
      --bg-secondary: #0d0d14;
      --bg-tertiary: #111119;
      --bg-card: rgba(255, 255, 255, 0.02);
      --bg-code: rgba(0, 0, 0, 0.4);
      
      --text-primary: #ffffff;
      --text-secondary: #e2e8f0;
      --text-muted: rgba(255, 255, 255, 0.7);
      --text-subtle: rgba(255, 255, 255, 0.5);
      
      --border-color: rgba(255, 255, 255, 0.06);
      --border-color-light: rgba(255, 255, 255, 0.1);
      
      --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.6);
      
      --accent-bg: rgba(99, 91, 255, 0.1);
      --accent-border: rgba(99, 91, 255, 0.2);
      
      --gradient-text: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.8) 100%);
      --gradient-accent: linear-gradient(135deg, #635bff 0%, #8b5cf6 100%);
      
      --overlay-bg: rgba(0, 0, 0, 0.8);
    }
    
    /* ===== 基础样式 ===== */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--bg-primary);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      transition: background-color 0.3s ease, color 0.3s ease;
    }
    
    a {
      color: inherit;
      text-decoration: none;
    }
    
    img {
      max-width: 100%;
      height: auto;
    }
    
    /* 滚动条样式 */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    
    ::-webkit-scrollbar-track {
      background: var(--bg-primary);
    }
    
    ::-webkit-scrollbar-thumb {
      background: var(--text-subtle);
      border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: var(--text-muted);
    }
    
    /* 选中文字样式 */
    ::selection {
      background: rgba(99, 91, 255, 0.3);
      color: white;
    }
  </style>
  
  <script>
    // 主题初始化（防止闪烁）
    (function() {
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const html = document.documentElement;
      
      if (savedTheme) {
        html.setAttribute('data-theme', savedTheme);
      } else if (prefersDark) {
        html.setAttribute('data-theme', 'dark');
      } else {
        html.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>
<body>
  <!-- 导航栏 -->
  <Navbar />
  
  <!-- Hero Section -->
  <Hero />
  
  <!-- Logo Marquee -->
  <LogoMarquee />
  
  <!-- Features Section -->
  <FeatureCards />
  
  <!-- Performance Section -->
  <PerformanceSection />
  
  <!-- Deployment Section -->
  <DeploymentSection />
  
  <!-- Verification Section -->
  <VerificationSection />
  
  <!-- CTA Section -->
  <CTASection />
  
  <!-- Footer -->
  <footer class="custom-footer">
    <div class="footer-content">
      <div class="footer-main">
        <div class="footer-brand">
          <svg class="footer-logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="url(#footer-logo-gradient)"/>
            <path d="M8 16h16M8 12h12M8 20h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <defs>
              <linearGradient id="footer-logo-gradient" x1="0" y1="0" x2="32" y2="32">
                <stop offset="0%" stop-color="#635bff"/>
                <stop offset="100%" stop-color="#8b5cf6"/>
              </linearGradient>
            </defs>
          </svg>
          <div class="footer-brand-info">
            <span class="footer-logo-text">smart-mqtt</span>
            <p class="footer-desc">企业级物联网消息中间件</p>
          </div>
        </div>
        
        <div class="footer-social">
          <a href="https://github.com/smartboot/smart-mqtt" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://gitee.com/smartboot/smart-mqtt" target="_blank" rel="noopener" aria-label="Gitee">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M11.984 0A12.01 12.01 0 0 0 0 12c0 5.285 3.42 9.767 8.16 11.354.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="footer-links">
        <div class="link-column">
          <h4>产品</h4>
          <a href="#features">功能特性</a>
          <a href="#performance">性能表现</a>
          <a href="#enterprise">企业服务</a>
        </div>
        <div class="link-column">
          <h4>开发者</h4>
          <a href="./product/introduction/">使用文档</a>
          <a href="./plugins/about/">关于Plugin</a>
        </div>
        <div class="link-column">
          <h4>资源</h4>
          <a href="./product/changelog/">更新日志</a>
          <a href="./product/choosing-broker/">选型指南</a>
        </div>
        <div class="link-column">
          <h4>关于</h4>
          <a href="https://smartboot.tech" target="_blank" rel="noopener">smartboot</a>
          <a href="https://github.com/smartboot/smart-mqtt" target="_blank" rel="noopener">GitHub</a>
          <a href="https://gitee.com/smartboot/smart-mqtt" target="_blank" rel="noopener">Gitee</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <p>&copy; 2024 smartboot. All rights reserved.</p>
        <div class="footer-stats">
          <span class="stat-item">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            900+ Stars
          </span>
          <span class="stat-divider"></span>
          <span class="stat-item">v1.5.2</span>
        </div>
      </div>
    </div>
  </footer>
  
  <style>
    .custom-footer {
      background: var(--bg-primary);
      border-top: 1px solid var(--border-color);
      padding: 80px 24px 0;
      transition: background-color 0.3s ease;
    }
    
    .footer-content {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 80px;
      padding-bottom: 60px;
    }
    
    .footer-main {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    
    .footer-brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .footer-logo-icon {
      width: 36px;
      height: 36px;
    }
    
    .footer-brand-info {
      display: flex;
      flex-direction: column;
    }
    
    .footer-logo-text {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }
    
    .footer-desc {
      color: var(--text-subtle);
      font-size: 14px;
      margin-top: 2px;
    }
    
    .footer-social {
      display: flex;
      gap: 12px;
    }
    
    .footer-social a {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      color: var(--text-muted);
      transition: all 0.2s;
    }
    
    .footer-social a:hover {
      background: var(--accent-bg);
      border-color: var(--accent-primary);
      color: var(--accent-primary);
    }
    
    .footer-links {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
    }
    
    .link-column {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    .link-column h4 {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
    }
    
    .link-column a {
      color: var(--text-subtle);
      font-size: 14px;
      transition: color 0.2s;
    }
    
    .link-column a:hover {
      color: var(--accent-primary);
    }
    
    .footer-bottom {
      border-top: 1px solid var(--border-color);
      padding: 24px;
    }
    
    .footer-bottom-content {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    
    .footer-bottom p {
      color: var(--text-subtle);
      font-size: 14px;
    }
    
    .footer-stats {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .stat-item {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--text-subtle);
      font-size: 14px;
    }
    
    .stat-item svg {
      color: var(--accent-primary);
    }
    
    .stat-divider {
      width: 1px;
      height: 16px;
      background: var(--border-color);
    }
    
    @media (max-width: 1024px) {
      .footer-content {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      
      .footer-links {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (max-width: 640px) {
      .custom-footer {
        padding: 60px 16px 0;
      }
      
      .footer-content {
        padding-bottom: 40px;
      }
      
      .footer-links {
        grid-template-columns: 1fr;
        gap: 24px;
      }
      
      .footer-bottom-content {
        flex-direction: column;
        text-align: center;
      }
    }
  </style>
</body>
</html>
